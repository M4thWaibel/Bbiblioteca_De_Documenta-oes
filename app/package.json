{
  "name": "biblioteca-de-documentacoes",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "description": "Biblioteca de Documentações — base de conhecimento pessoal com projetos, biblioteca de documentos em Markdown e quadro de tarefas. React + Vite + Supabase.",
