    "@vitejs/plugin-react": "^4.3.2",
    "eslint": "^10.6.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "globals": "^17.7.0",
    "typescript": "^5.6.2",
    "typescript-eslint": "^8.63.0",
    "vite": "^5.4.8",
    "vitest": "^4.1.10"
  }
}
